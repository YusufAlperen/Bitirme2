<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:orientation="horizontal">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:layout_marginEnd="8dp" />

        <FrameLayout
            android:id="@+id/skeletonContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/ivSkeleton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#222222"
                android:scaleType="fitCenter"
                android:contentDescription="İskelet" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvMod"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Şu an: -"
            android:textColor="#FFD54F"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ToggleButton
            android:id="@+id/btnSkeletonToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textOn="İskelet: AÇIK"
            android:textOff="İskelet: KAPALI"
            android:checked="true"
            android:textSize="11sp"
            android:minHeight="36dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:backgroundTint="#37474F"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTop1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="-"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Seçenekler (tıklayarak ekle):"
        android:textColor="#888888"
        android:textSize="11sp" />

    <LinearLayout
        android:id="@+id/llTopK"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/tvTop1Click"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:padding="10dp"
            android:gravity="center"
            android:background="#263238"
            android:text="-"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvTop2Click"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:padding="10dp"
            android:gravity="center"
            android:background="#263238"
            android:text="-"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvTop3Click"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:padding="10dp"
            android:gravity="center"
            android:background="#263238"
            android:text="-"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:clickable="true"
            android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bakış Durumu: "
                android:textColor="@color/black"
                android:textStyle="bold" />

            <View
                android:id="@+id/vStatusLight"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@android:color/holo_red_dark" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Tahmin edilenler (silmek için tıkla):"
        android:textColor="#888888"
        android:textSize="11sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/llRawWords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:minHeight="40dp" />
    </HorizontalScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Cümle:"
        android:textColor="#888888"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tvSentence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:minHeight="56dp"
        android:padding="10dp"
        android:background="#1E1E1E"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="17sp" />

    <Button
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Cümleyi Sıfırla"
        android:backgroundTint="#E53935"
        android:textColor="#FFFFFF" />

</LinearLayout>